<script>
    const counters = document.querySelectorAll('.counter');

counters.forEach(counter => {
    const target = parseFloat(counter.dataset.target);
    const type = counter.dataset.type;
    let count = 0;

    const updateCounter = () => {
        const increment = target / 360;

        if (count < target) {
            count += increment;

            if (type === "percent") {
                counter.innerText = 
                    (target % 1 !== 0 ? count.toFixed(1) : Math.floor(count)) + "%";
            } else if (type === "hours") {
                counter.innerText = Math.floor(count) + "/7";
            }

            requestAnimationFrame(updateCounter);
        } else {
            if (type === "percent") {
                counter.innerText = target + "%";
            } else if (type === "hours") {
                counter.innerText = target + "/7";
            }
        }
    };

    updateCounter();
});
    
    function toggleDropdown(element) {
        const card = element.parentElement;
        const details = card.querySelector('.feature-details');
        const icon = element.querySelector('.dropdown-icon');
        
        // Close all other dropdowns
        document.querySelectorAll('.feature-details').forEach(detail => {
            if (detail !== details) {
                detail.classList.remove('active');
            }
        });
        
        document.querySelectorAll('.dropdown-icon').forEach(ico => {
            if (ico !== icon) {
                ico.classList.remove('active');
            }
        });
        
        // Toggle current dropdown
        details.classList.toggle('active');
        icon.classList.toggle('active');
        function toggleProperty(element) {
       const details = element.nextElementSibling;
        const arrow = element.querySelector('.arrow');

      // Close other open properties
     document.querySelectorAll('.property-details').forEach(d => {
        if (d !== details) d.classList.remove('active');
     });
     document.querySelectorAll('.property-header .arrow').forEach(a => {
        if (a !== arrow) a.classList.remove('active');
     });

     // Toggle current property
     details.classList.toggle('active');
     arrow.classList.toggle('active');
     }
     }
     function toggleDropdown(element) {
    const card = element.parentElement;
    const details = card.querySelector('.feature-details');
    const icon = element.querySelector('.dropdown-icon');

    // Close all other dropdowns
    document.querySelectorAll('.feature-details').forEach(detail => {
        if (detail !== details) {
            detail.classList.remove('active');
        }
    });

    document.querySelectorAll('.dropdown-icon').forEach(ico => {
        if (ico !== icon) {
            ico.classList.remove('active');
        }
    });

    // Toggle current dropdown
    details.classList.toggle('active');
    icon.classList.toggle('active');
}

function toggleBrokers() {
    const brokers = document.getElementById("brokers");
    if (brokers.style.display === "none" || brokers.style.display === "") {
        brokers.style.display = "block";           // Show section
        brokers.scrollIntoView({behavior: "smooth"}); // Scroll smoothly
    } else {
        brokers.style.display = "none";            // Hide section
    }
}
const btn = document.getElementById('showEmploymentBtn');
    const section = document.getElementById('employmentSection');

    btn.addEventListener('click', () => {
        section.style.display = section.style.display === 'none' ? 'block' : 'none';
        btn.textContent = section.style.display === 'block' ? 'Hide Employment Opportunities' : 'View Employment Opportunities';
    });
    // Get the button and employment section
    const showEmploymentBtn = document.getElementById('showEmploymentBtn');
    const employmentSection = document.getElementById('employmentSection');

    // Add click event
    showEmploymentBtn.addEventListener('click', () => {
        if (employmentSection.style.display === 'none') {
            employmentSection.style.display = 'block';
            // Scroll to it
            employmentSection.scrollIntoView({ behavior: 'smooth' });
        } else {
            employmentSection.style.display = 'none';
        }
    });
const navLink = document.querySelector('a[href="#employmentSection"]');

navLink.addEventListener('click', (e) => {
    e.preventDefault(); // Prevent default jump
    section.style.display = 'block';
    section.scrollIntoView({ behavior: 'smooth' });
});
function showEmployment() {
    const section = document.getElementById('employmentSection');
    if (section.style.display === 'none' || section.style.display === '') {
        section.style.display = 'block';
        section.scrollIntoView({ behavior: 'smooth' });
    } else {
        section.style.display = 'none';
    }
}

</script>

